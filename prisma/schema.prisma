generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Tutor Config (managed via admin) ───────────────────────────────────────

model Tutor {
  id           String   @id // slug: "socrates", "jake-peralta", etc.
  name         String
  description  String
  avatar       String
  image        String?
  scene        String?
  systemPrompt String // legacy — deprecated after v2 persona layers stable
  // ─── v2 persona layers ────────────────────────────────────────────────────
  identity         String  @default("")
  voiceTraits      Json    @default("[]")
  antiPatterns     Json    @default("[]")
  goldenLines      Json    @default("{}")
  vocabulary       Json    @default("[]")
  glossary         Json    @default("{}")
  teachingArc      Json    @default("{}")
  liveContext      Json?
  webSearchEnabled Boolean @default(false)
  // ──────────────────────────────────────────────────────────────────────────
  sortOrder    Int      @default(0)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Anonymous Session ──────────────────────────────────────────────────────

model Session {
  id         String   @id @default(cuid())
  sessionId  String   @unique
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  studySets       StudySet[]
  uploads         Upload[]
  tests           Test[]
  testSessions    TestSession[]
  cards           Card[]
  recommendations Recommendation[]

  @@index([lastSeenAt])
}

// ─── App Models ─────────────────────────────────────────────────────────────

model StudySet {
  id          String   @id @default(cuid())
  sessionId   String
  title       String
  description String?
  createdAt   DateTime @default(now())

  session Session  @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  uploads Upload[]
  tests   Test[]

  @@index([sessionId])
}

model Upload {
  id            String   @id @default(cuid())
  studySetId    String
  sessionId     String
  fileName      String
  fileKey       String
  fileType      String
  extractedText String?
  concepts      Json     @default("[]")
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  studySet StudySet @relation(fields: [studySetId], references: [id], onDelete: Cascade)
  session  Session  @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId])
}

enum TestType {
  QUIZ
  FLASHCARD
  REVERSE_FLASHCARD
}

model Test {
  id         String   @id @default(cuid())
  studySetId String
  sessionId  String
  type       TestType
  config     Json     @default("{}")
  questions  Json
  createdAt  DateTime @default(now())

  studySet StudySet      @relation(fields: [studySetId], references: [id], onDelete: Cascade)
  session  Session       @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  sessions TestSession[]
  cards    Card[]

  @@index([sessionId])
}

model TestSession {
  id             String    @id @default(cuid())
  testId         String
  sessionId      String
  score          Float?
  totalQuestions Int?
  results        Json
  weakConcepts   Json      @default("[]")
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  test            Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  session         Session          @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  recommendations Recommendation[]

  @@index([sessionId])
}

model Card {
  id           String   @id @default(cuid())
  testId       String
  sessionId    String
  front        String
  back         String
  intervalDays Float    @default(1)
  easeFactor   Float    @default(2.5)
  nextReview   DateTime @default(now())
  reviewCount  Int      @default(0)

  test    Test    @relation(fields: [testId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId])
}

model Recommendation {
  id         String   @id @default(cuid())
  sessionRef String
  sessionId  String
  concept    String
  sourceUrl  String
  sourceName String?
  summary    String?
  saved      Boolean  @default(false)
  createdAt  DateTime @default(now())

  testSession TestSession @relation(fields: [sessionRef], references: [id], onDelete: Cascade)
  session     Session     @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId])
}
