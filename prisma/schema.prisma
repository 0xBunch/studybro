generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Adapter Models ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  studySets       StudySet[]
  uploads         Upload[]
  tests           Test[]
  testSessions    TestSession[]
  cards           Card[]
  recommendations Recommendation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── App Models ─────────────────────────────────────────────────────────────

model StudySet {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  createdAt   DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploads Upload[]
  tests   Test[]
}

model Upload {
  id            String   @id @default(cuid())
  studySetId    String
  userId        String
  fileName      String
  fileKey       String
  fileType      String
  extractedText String?
  concepts      Json     @default("[]")
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  studySet StudySet @relation(fields: [studySetId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TestType {
  QUIZ
  FLASHCARD
  REVERSE_FLASHCARD
}

model Test {
  id         String   @id @default(cuid())
  studySetId String
  userId     String
  type       TestType
  config     Json     @default("{}")
  questions  Json
  createdAt  DateTime @default(now())

  studySet StudySet      @relation(fields: [studySetId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions TestSession[]
  cards    Card[]
}

model TestSession {
  id             String    @id @default(cuid())
  testId         String
  userId         String
  score          Float?
  totalQuestions  Int?
  results        Json
  weakConcepts   Json      @default("[]")
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  test            Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]
}

model Card {
  id           String   @id @default(cuid())
  testId       String
  userId       String
  front        String
  back         String
  intervalDays Float    @default(1)
  easeFactor   Float    @default(2.5)
  nextReview   DateTime @default(now())
  reviewCount  Int      @default(0)

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Recommendation {
  id         String  @id @default(cuid())
  sessionId  String
  userId     String
  concept    String
  sourceUrl  String
  sourceName String?
  summary    String?
  saved      Boolean @default(false)
  createdAt  DateTime @default(now())

  session TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}
